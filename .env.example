# Скопируйте в .env и при необходимости поправьте порты
COMPOSE_PROJECT_NAME=shoria

POSTGRES_DB=shoria
POSTGRES_USER=shoria
POSTGRES_PASSWORD=shoria
POSTGRES_PORT=5432

REDIS_PORT=6379

HTTP_PORT=8080
VITE_PORT=5173

# Тот же базовый URL, что в адресной строке при открытии Laravel/Filament
APP_URL=http://localhost:8080

# Браузер на хосте ходит на API по этому адресу (для Vite env)
VITE_API_URL=http://localhost:8080

APP_ENV=local
APP_DEBUG=true

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# UID/GID на Linux для сервиса composer (на macOS можно не задавать)
# DOCKER_UID=1000
# DOCKER_GID=1000
